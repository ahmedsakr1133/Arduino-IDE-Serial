<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_page"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:background="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/serial_settings"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/languageSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/themeSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/baud_rate"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/baudSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/data_bits"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/dataBitsSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/stop_bits"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/stopBitsSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/parity"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/paritySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/line_ending"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/lineEndingSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/server_port"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/serverPortInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="@string/port_hint"
            android:inputType="number"
            android:paddingHorizontal="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/manual_ip"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/manualIpInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="@string/ip_hint"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/save"
            android:textAllCaps="false"
            android:textColor="@color/text_on_primary"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/closeButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_button_secondary"
            android:text="@string/close"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
