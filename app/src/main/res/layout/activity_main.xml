<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:fitsSystemWindows="true"
    android:background="@color/surface_page">

    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_page"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Connection Group -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_group_box"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connection"
                android:textColor="@color/terminal_sys"
                android:textSize="9sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/connectionSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/switch_off"
                app:trackTint="@color/border_medium" />
        </LinearLayout>

        <!-- Server Group -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_group_box"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/server"
                android:textColor="@color/terminal_sys"
                android:textSize="9sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/serverSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/switch_off"
                    app:trackTint="@color/border_medium" />

                <ImageButton
                    android:id="@+id/copyServerAddress"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"
                    android:scaleType="centerInside"
                    android:src="@android:drawable/ic_menu_edit"
                    android:visibility="gone"
                    app:tint="@color/terminal_rx" />
            </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/clearButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/clear"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/settings"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@color/text_primary" />
    </LinearLayout>

    <!-- Terminal Display -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/terminalRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/terminal_bg"
        android:layoutDirection="ltr"
        android:textDirection="ltr"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@id/statusBar"
        app:layout_constraintTop_toBottomOf="@id/controlBar" />

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="@color/surface_status"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        app:layout_constraintBottom_toTopOf="@id/navBar">

        <TextView
            android:id="@+id/receivedStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/received_bytes"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/sentStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/sent_bytes"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/ic_status_dot" />

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disconnected"
            android:textColor="@color/terminal_err"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Nav Bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@color/surface_accent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="0dp"
        app:layout_constraintBottom_toTopOf="@id/inputBar">

        <ImageButton
            android:id="@+id/prevCommand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_nav_button"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/arrow_up_float"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/nextCommand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_nav_button"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@color/text_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <CheckBox
            android:id="@+id/autoScrollCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/auto_send"
            android:textColor="@color/text_primary"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_tool"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="8dp">

            <EditText
                android:id="@+id/commandInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:fontFamily="monospace"
                android:hint="@string/write_command"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textColorHint="#666666"
                android:textSize="12sp" />
        </FrameLayout>

        <ImageButton
            android:id="@+id/sendButton"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_button_primary"
            android:contentDescription="@string/send"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_send"
            app:tint="@color/text_on_primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
