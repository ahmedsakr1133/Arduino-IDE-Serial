<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:fitsSystemWindows="true"
    android:background="@color/surface_page">

    <LinearLayout
        android:id="@+id/controlBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_accent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/connectButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_primary"
            android:padding="0dp"
            android:text="@string/connect"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/disconnectButton"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginHorizontal="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_secondary"
            android:enabled="false"
            android:padding="0dp"
            android:text="@string/disconnect"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/clearButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/clear"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_button_secondary"
            android:contentDescription="@string/settings"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_menu_preferences"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Terminal Display -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/terminalRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#000000"
        android:layoutDirection="ltr"
        android:textDirection="ltr"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@id/statusBar"
        app:layout_constraintTop_toBottomOf="@id/controlBar" />

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:background="@color/surface_status"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        app:layout_constraintBottom_toTopOf="@id/navBar">

        <TextView
            android:id="@+id/receivedStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/received_bytes"
            android:textColor="#E2E8F0"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/sentStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/sent_bytes"
            android:textColor="#E2E8F0"
            android:textSize="10sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/ic_status_dot" />

        <TextView
            android:id="@+id/connectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/disconnected"
            android:textColor="@color/terminal_err"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Nav Bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@color/surface_accent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingVertical="0dp"
        app:layout_constraintBottom_toTopOf="@id/inputBar">

        <ImageButton
            android:id="@+id/prevCommand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_nav_button"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/arrow_up_float"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/nextCommand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_nav_button"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/arrow_down_float"
            app:tint="@android:color/white" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <CheckBox
            android:id="@+id/autoScrollCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/auto_send"
            android:textColor="@android:color/white"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_tool"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_rounded"
            android:paddingHorizontal="8dp">

            <EditText
                android:id="@+id/commandInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:fontFamily="monospace"
                android:hint="@string/write_command"
                android:imeOptions="actionSend"
                android:inputType="text"
                android:textColor="@android:color/white"
                android:textColorHint="#666666"
                android:textSize="12sp" />
        </FrameLayout>

        <Button
            android:id="@+id/sendButton"
            android:layout_width="54dp"
            android:layout_height="32dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_button_primary"
            android:padding="0dp"
            android:text="@string/send"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
